	Range = {60,300},
	Increment = 10,
	CurrentValue = 140,
	Callback = function(v)
		TWEEN_SPEED = v
	end
})

Tab:CreateButton({
	Name = "🔄 Atualizar",
	Callback = function()
		scan()
	end
})

