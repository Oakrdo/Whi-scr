local function isRockModel(model)
    if not model or not model:IsA("Model") then return false, nil end
    if not string.find(model.Name, "{") then return false, nil end
    if isWildHorse(model) or isHerd(model) then return false, nil end

    local isOre = false
    local rockPart = nil

    for _, child in ipairs(model:GetDescendants()) do
        if child:IsA("BasePart") then
            local name = string.lower(child.Name)

            if name == "rocks" then
                isOre = true
                rockPart = child
            end
            if string.find(name, "rocks") and not rockPart then
                rockPart = child
            end
        end
    end

    if onlyOreRocks and not isOre then
        return false, nil
    end

    return rockPart ~= nil, rockPart
end

local function isSnowballModel(model)
    if not model or not model:IsA("Model") then return false, nil end
    for _, child in ipairs(model:GetDescendants()) do
        if child:IsA("BasePart") or child:IsA("MeshPart") then
            if string.find(string.lower(child.Name), "snowball") then
                return true, child
            end
        end
    end
    return false, nil
end

