-- UI
--------------------------------------------------
local info = Tab:CreateLabel("Cavalos/h: 0")

Tab:CreateToggle({
	Name = "▶ Auto Farm",
	CurrentValue = false,
	Callback = function(v)
		following = v
		if v then
			scan()
			local i = getBestHorse()
			if i then
				index = i
				goTo(horses[index])
			end
		end
	end
})

