local function getCollectibleInfo(model)
    if not model or not model:IsA("Model") then return nil, nil end

    if string.find(model.Name, "{") then
        local children = model:GetChildren()
        if #children == 1 and children[1].Name == "Primary" and (children[1]:IsA("BasePart") or children[1]:IsA("MeshPart")) then
            if not excludeItems.concha then
                return "concha", children[1]
            end
        end
    end

    local children = model:GetChildren()
    if #children == 1 and children[1]:IsA("BasePart") and children[1].Name == "Part" then
        if not excludeItems.perola then
            return "perola", children[1]
        end
    end

    local targetPart = nil
    local itemType = nil

    for _, child in ipairs(model:GetDescendants()) do
        if child:IsA("BasePart") or child:IsA("MeshPart") then
            local name = string.lower(child.Name)

            if string.find(name, "cotton") then
                if not excludeItems.algodao then targetPart = child; itemType = "algodao"; break end
            end
            if string.find(name, "wheat") then
                if not excludeItems.trigo then targetPart = child; itemType = "trigo"; break end
            end
            if string.find(name, "corn") then
                if not excludeItems.milho then targetPart = child; itemType = "milho"; break end
            end
            if string.find(name, "bush") then
                if not excludeItems.bush then targetPart = child; itemType = "bush"; break end
            end
            if string.find(name, "flower") then
                if not excludeItems.flor then targetPart = child; itemType = "flor"; break end
            end
            if string.find(name, "berry") then
                if not excludeItems.berry then targetPart = child; itemType = "berry"; break end
            end
            if string.find(name, "coconut") then
                if not excludeItems.coco then targetPart = child; itemType = "coco"; break end
            end
            if string.find(name, "pearl") or string.find(name, "perola") then
                if not excludeItems.perola then targetPart = child; itemType = "perola"; break end
            end
            if string.find(name, "shell") or string.find(name, "conch") then
                if not excludeItems.concha then targetPart = child; itemType = "concha"; break end
            end
            if name == "bounds" or name == "hitbox" then
                if not excludeItems.item then targetPart = child; itemType = "item" end
            end
        end
    end

    return itemType, targetPart
end

