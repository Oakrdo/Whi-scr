local function dist(a, b)
    if not a or not b then return math.huge end
    local posA = typeof(a) == "Vector3" and a or (a.Position or a.p)
    local posB = typeof(b) == "Vector3" and b or (b.Position or b.p)
    if not posA or not posB then return math.huge end
    return (posA - posB).Magnitude
end

local function stopMovement()
    if activeTween then
        pcall(function() activeTween:Cancel() end)
        activeTween = nil
    end
end

local function moveTo(pos, lookAt)
    stopMovement()
    if not HRP or not HRP.Parent then return nil end

    local targetPos = typeof(pos) == "Vector3" and pos or pos.Position
    local targetCF
    if lookAt then
        local lookPos = typeof(lookAt) == "Vector3" and lookAt or lookAt.Position
        targetCF = CFrame.new(targetPos, lookPos)
    else
        targetCF = CFrame.new(targetPos)
    end

    local d = (targetPos - HRP.Position).Magnitude
    local t = math.max(d / tweenSpeed, 0.1)

    activeTween = TweenService:Create(HRP, TweenInfo.new(t, Enum.EasingStyle.Linear), {CFrame = targetCF})
    activeTween:Play()

    return activeTween
end

