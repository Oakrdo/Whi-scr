local function getCurrentIsland()
    if not HRP then return nil end
    local islands = Workspace:FindFirstChild("Islands")
    if not islands then return nil end
    for _, island in ipairs(islands:GetChildren()) do
        if island:FindFirstChild(PLAYER_NAME) then
            return island
        end
    end
    local nearest, minDist = nil, math.huge
    for _, island in ipairs(islands:GetChildren()) do
        local part = island:FindFirstChildWhichIsA("BasePart", true)
        if part then
            local d = dist(HRP, part)
            if d < minDist and d < 500 then
                local hasTerrain = island:FindFirstChild("Terrain") 
                    or island:FindFirstChild("Sand") 
                    or island:FindFirstChild("Grass")
                    or island:FindFirstChild("Ground")
                if hasTerrain then
                    minDist = d
                    nearest = island
                end
            end
        end
    end
    return nearest
end

