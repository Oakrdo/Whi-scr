                    local isRock, part = isRockModel(m)
                    if isRock and part and part:IsA("BasePart") and part.Parent then
                        local hasPlayer, _ = isPlayerNear(part.Position, 20)
                        if not hasPlayer then
                            local d = dist(part, HRP)
                            if d < minDist then
                                minDist = d
                                target = part
                            end
                        end
                    end
                end
            end
        end

        if target then
            currentTarget = "Pedra: " .. target.Name .. (onlyOreRocks and " [MINÉRIO]" or "")
            local distToRock = dist(target, HRP)

            if distToRock > 5 then
                moveTo(target.Position + Vector3.new(0, 3, 0))
                task.wait(0.3)
            else
                activateTool()
                task.wait(0.3)
                if not target.Parent then
                    rockCount += 1
                end
            end
        else
            currentTarget = "Sem pedras"
        end
    end
end)

