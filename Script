local function getHorseLabels(horse)
    if not horse or not horse:IsA("Model") then return nil, nil end
    local ohp = horse:FindFirstChild("OverheadPart")
    if not ohp then return nil, nil end
    local oh = ohp:FindFirstChild("Overhead")
    if not oh then return nil, nil end
    local bl = oh:FindFirstChild("BreedLabel")
    local nl = oh:FindFirstChild("NameLabel")
    local breedText = bl and bl:IsA("TextLabel") and bl.Text or nil
    local nameText = nl and nl:IsA("TextLabel") and nl.Text or nil
    return breedText, nameText
end

local function isHorseTamed(horse)
    local breedText, nameText = getHorseLabels(horse)
    if breedText and string.find(breedText, "'") then return true, breedText end
    return false, breedText
end

local function isMyHorse(horse)
    local breedText, _ = getHorseLabels(horse)
    if not breedText then return false end
    local lowerBreed = string.lower(breedText)
    local lowerName = string.lower(PLAYER_NAME)
    if string.find(lowerBreed, lowerName .. "'s") then return true end
    return false
end

local function isHerd(horse)
    if not horse or not horse:IsA("Model") then return false end
    if not string.find(horse.Name, "{") then return false end
    if not horse:FindFirstChild("HumanoidRootPart") then return false end
    if not horse:FindFirstChild("Humanoid") then return false end
    if horse.Parent ~= Workspace then return false end
    local breedText, nameText = getHorseLabels(horse)
    if nameText and string.lower(nameText) == "wild" then return true end
    return false
end

local function isWildHorse(horse)
    if not horse or not horse:IsA("Model") then return false end
    if not string.find(horse.Name, "{") then return false end
    if not horse:FindFirstChild("HumanoidRootPart") then return false end
    if not horse:FindFirstChild("Humanoid") then return false end
    local parent = horse.Parent
    local isInIsland = false
    while parent do
        if parent.Name == "Islands" or (parent.Parent and parent.Parent.Name == "Islands") then
            isInIsland = true
            break
        end
        parent = parent.Parent
    end
    if not isInIsland then return false end
    local breedText, nameText = getHorseLabels(horse)
    if nameText and string.lower(nameText) == "wild" then return true end
    if breedText and not string.find(breedText, "'") then return true end
    return false
end

local function getHorseBreedForFilter(horse)
    local breedText, _ = getHorseLabels(horse)
    if not breedText then return "Desconhecida" end
    local pure = string.match(breedText, "'s%s+(.+)$") or breedText
    return pure
end

local function checkHorseState(horse)
    if not horse then return "gone" end
    if not horse.Parent then return "gone" end

    local hrpHorse = horse:FindFirstChild("HumanoidRootPart")
    if not hrpHorse then return "gone" end

    if isMyHorse(horse) then return "mine" end

    local isTamed, _ = isHorseTamed(horse)
    if isTamed then return "tamed" end

    return "wild"
end

